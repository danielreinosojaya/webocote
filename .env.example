# Google Analytics 4 (opcional). Aťade en Vercel ? Settings ? Environment Variables.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel (opcional). ID numťrico desde Events Manager en Meta Ads.
VITE_META_PIXEL_ID=

# Google Search Console ť meta de verificaciťn (opcional).
VITE_GOOGLE_SITE_VERIFICATION=

# Neon PostgreSQL (Vercel integration o manual).
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Control sanitario /temperatura ť cťdigo numťrico de 4 a 6 dťgitos.
TEMPERATURA_PIN=1234

# Control de compras /compras — codigo numerico de 4 a 6 digitos.
# Si no se define, usa TEMPERATURA_PIN.
COMPRAS_PIN=1234

# Firma de sesiťn (opcional; si no se define, usa TEMPERATURA_PIN).
SESSION_SECRET=genera-un-string-aleatorio-largo
