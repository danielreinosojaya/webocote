# Google Analytics 4 (opcional). Ańade en Vercel ? Settings ? Environment Variables.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console — meta de verificación (opcional).
VITE_GOOGLE_SITE_VERIFICATION=

# Neon PostgreSQL (Vercel integration o manual).
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Control sanitario /temperatura — código numérico de 4 a 6 dígitos.
TEMPERATURA_PIN=1234

# Firma de sesión (opcional; si no se define, usa TEMPERATURA_PIN).
SESSION_SECRET=genera-un-string-aleatorio-largo
