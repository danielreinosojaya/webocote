{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "ocotemadrid.com" }],
      "destination": "https://www.ocote.es/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.ocotemadrid.com" }],
      "destination": "https://www.ocote.es/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "ocote.es" }],
      "destination": "https://www.ocote.es/:path*",
      "permanent": true
    }
  ]
}
